# PTA Pilot environment contract
# Copy the web section into apps/web/.env.local
# Copy the API section into apps/api/.env

# -----------------------------------------------------------------------------
# Web app (apps/web/.env.local)
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
PTA_API_BASE_URL=http://localhost:8081
AUTH0_DOMAIN=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
AUTH0_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
AUTH0_AUDIENCE=
AUTH0_SCOPE="openid profile email"
AUTH0_TOKEN_VAULT_CONNECTION=google-oauth2
AUTH0_GMAIL_CONNECTION=google-oauth2
AUTH0_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.compose,https://www.googleapis.com/auth/gmail.send

# -----------------------------------------------------------------------------
# API service (apps/api/.env)
# -----------------------------------------------------------------------------
PORT=8081
APP_BASE_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:3000
AUTH0_DOMAIN=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
AUTH0_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
AUTH0_APP_BASE_URL=http://localhost:3000
AUTH0_AUDIENCE=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_API_SCOPE="read:users read:user_idp_tokens"
AUTH0_TOKEN_VAULT_CONNECTION=google-oauth2
AUTH0_TOKEN_VAULT_PROVIDER=google-oauth2
AUTH0_TOKEN_VAULT_ACCOUNT_ID=
AUTH0_GMAIL_CONNECTION=google-oauth2
AUTH0_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.compose,https://www.googleapis.com/auth/gmail.send
MEMBERSHIP_TOOLKIT_BASE_URL=
MEMBERSHIP_TOOLKIT_USERNAME=
MEMBERSHIP_TOOLKIT_PASSWORD=
MEMBERSHIP_TOOLKIT_STORAGE_STATE_PATH=
MEMBERSHIP_TOOLKIT_LOGIN_TIMEOUT_MS=30000
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-3.1-pro-preview
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
MEMBERSHIP_TOOLKIT_MODE=mock
FLYER_MODE=mock
DEMO_RUNTIME_STATE_PATH=
